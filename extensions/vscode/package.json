{
  "name": "aweshelf",
  "displayName": "Aweshelf Bookmarks",
  "description": "Browse, search, and resume aweshelf AI coding session bookmarks from VS Code.",
  "version": "0.0.1",
  "publisher": "webioinfo",
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Webioinfo01/aweshelf.git",
    "directory": "extensions/vscode"
  },
  "bugs": {
    "url": "https://github.com/Webioinfo01/aweshelf/issues"
  },
  "homepage": "https://github.com/Webioinfo01/aweshelf",
  "engines": {
    "vscode": "^1.85.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "categories": [
    "Other"
  ],
  "keywords": [
    "aweshelf",
    "ai",
    "agent",
    "claude",
    "codex",
    "bookmark",
    "session"
  ],
  "activationEvents": [
    "onView:aweshelfBookmarks",
    "onCommand:aweshelf.refresh",
    "onCommand:aweshelf.searchBookmarks",
    "onCommand:aweshelf.clearSearch",
    "onCommand:aweshelf.sortBookmarks",
    "onCommand:aweshelf.filterProvider",
    "onCommand:aweshelf.filterCategory",
    "onCommand:aweshelf.clearFilters",
    "onCommand:aweshelf.bookmarkSession",
    "onCommand:aweshelf.showBookmarkDetail",
    "onCommand:aweshelf.copySessionId",
    "onCommand:aweshelf.copyResumeCommand",
    "onCommand:aweshelf.openProjectPath",
    "onCommand:aweshelf.editBookmark",
    "onCommand:aweshelf.removeBookmark",
    "onCommand:aweshelf.resumeBookmarkWithProfile",
    "onCommand:aweshelf.resumeBookmarkRaw",
    "onCommand:aweshelf.resumeBookmark",
    "onCommand:aweshelf.bookmarkCurrent",
    "onCommand:aweshelf.bookmarkCurrentInTerminal",
    "onCommand:aweshelf.showStatus"
  ],
  "main": "./out/src/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test out/test/*.test.js",
    "package": "vsce package",
    "vscode:prepublish": "npm run compile"
  },
  "contributes": {
    "configuration": {
      "title": "Aweshelf",
      "properties": {
        "aweshelf.commandPath": {
          "type": "string",
          "default": "aweshelf",
          "description": "Path to the aweshelf executable."
        },
        "aweshelf.configPath": {
          "type": "string",
          "default": "",
          "description": "Optional AWESHELF_CONFIG path used when running aweshelf."
        }
      }
    },
    "commands": [
      {
        "command": "aweshelf.refresh",
        "title": "Aweshelf: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "aweshelf.searchBookmarks",
        "title": "Aweshelf: Search Bookmarks",
        "icon": "$(search)"
      },
      {
        "command": "aweshelf.clearSearch",
        "title": "Aweshelf: Clear Search",
        "icon": "$(clear-all)"
      },
      {
        "command": "aweshelf.sortBookmarks",
        "title": "Aweshelf: Sort Bookmarks",
        "icon": "$(sort-precedence)"
      },
      {
        "command": "aweshelf.filterProvider",
        "title": "Aweshelf: Filter by Provider",
        "icon": "$(filter)"
      },
      {
        "command": "aweshelf.filterCategory",
        "title": "Aweshelf: Filter by Category",
        "icon": "$(filter)"
      },
      {
        "command": "aweshelf.clearFilters",
        "title": "Aweshelf: Clear Filters",
        "icon": "$(clear-all)"
      },
      {
        "command": "aweshelf.bookmarkSession",
        "title": "Aweshelf: Bookmark Session",
        "icon": "$(list-selection)"
      },
      {
        "command": "aweshelf.showBookmarkDetail",
        "title": "Aweshelf: Show Bookmark Details",
        "icon": "$(info)"
      },
      {
        "command": "aweshelf.copySessionId",
        "title": "Aweshelf: Copy Session ID",
        "icon": "$(copy)"
      },
      {
        "command": "aweshelf.copyResumeCommand",
        "title": "Aweshelf: Copy Resume Command",
        "icon": "$(terminal)"
      },
      {
        "command": "aweshelf.openProjectPath",
        "title": "Aweshelf: Open Project Path",
        "icon": "$(folder-opened)"
      },
      {
        "command": "aweshelf.editBookmark",
        "title": "Aweshelf: Edit Bookmark",
        "icon": "$(edit)"
      },
      {
        "command": "aweshelf.removeBookmark",
        "title": "Aweshelf: Remove Bookmark",
        "icon": "$(trash)"
      },
      {
        "command": "aweshelf.resumeBookmarkWithProfile",
        "title": "Aweshelf: Resume Bookmark with Profile",
        "icon": "$(account)"
      },
      {
        "command": "aweshelf.resumeBookmarkRaw",
        "title": "Aweshelf: Resume Bookmark Raw",
        "icon": "$(terminal-cmd)"
      },
      {
        "command": "aweshelf.resumeBookmark",
        "title": "Aweshelf: Resume Bookmark",
        "icon": "$(debug-start)"
      },
      {
        "command": "aweshelf.bookmarkCurrent",
        "title": "Aweshelf: Bookmark Current Session",
        "icon": "$(bookmark)"
      },
      {
        "command": "aweshelf.bookmarkCurrentInTerminal",
        "title": "Aweshelf: Bookmark Current Session in Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "aweshelf.showStatus",
        "title": "Aweshelf: Show Status",
        "icon": "$(pulse)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aweshelf",
          "title": "Aweshelf",
          "icon": "resources/aweshelf.svg"
        }
      ]
    },
    "views": {
      "aweshelf": [
        {
          "id": "aweshelfBookmarks",
          "name": "Bookmarks"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "aweshelfBookmarks",
        "contents": "No aweshelf bookmarks found.\n[Refresh](command:aweshelf.refresh)\n[Bookmark Current Session](command:aweshelf.bookmarkCurrent)\n[Bookmark Another Session](command:aweshelf.bookmarkSession)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "aweshelf.refresh",
          "when": "view == aweshelfBookmarks",
          "group": "navigation@1"
        },
        {
          "command": "aweshelf.searchBookmarks",
          "when": "view == aweshelfBookmarks",
          "group": "navigation@2"
        },
        {
          "command": "aweshelf.clearSearch",
          "when": "view == aweshelfBookmarks",
          "group": "navigation@3"
        },
        {
          "command": "aweshelf.sortBookmarks",
          "when": "view == aweshelfBookmarks",
          "group": "navigation@4"
        },
        {
          "command": "aweshelf.filterProvider",
          "when": "view == aweshelfBookmarks",
          "group": "navigation@5"
        },
        {
          "command": "aweshelf.filterCategory",
          "when": "view == aweshelfBookmarks",
          "group": "navigation@6"
        },
        {
          "command": "aweshelf.clearFilters",
          "when": "view == aweshelfBookmarks",
          "group": "navigation@7"
        },
        {
          "command": "aweshelf.bookmarkSession",
          "when": "view == aweshelfBookmarks",
          "group": "navigation@8"
        },
        {
          "command": "aweshelf.showStatus",
          "when": "view == aweshelfBookmarks",
          "group": "navigation@9"
        }
      ],
      "view/item/context": [
        {
          "command": "aweshelf.showBookmarkDetail",
          "when": "view == aweshelfBookmarks && viewItem == aweshelfBookmark",
          "group": "navigation@1"
        },
        {
          "command": "aweshelf.editBookmark",
          "when": "view == aweshelfBookmarks && viewItem == aweshelfBookmark",
          "group": "navigation@2"
        },
        {
          "command": "aweshelf.resumeBookmark",
          "when": "view == aweshelfBookmarks && viewItem == aweshelfBookmark",
          "group": "navigation@3"
        },
        {
          "command": "aweshelf.resumeBookmarkWithProfile",
          "when": "view == aweshelfBookmarks && viewItem == aweshelfBookmark",
          "group": "navigation@4"
        },
        {
          "command": "aweshelf.resumeBookmarkRaw",
          "when": "view == aweshelfBookmarks && viewItem == aweshelfBookmark",
          "group": "navigation@5"
        },
        {
          "command": "aweshelf.copySessionId",
          "when": "view == aweshelfBookmarks && viewItem == aweshelfBookmark",
          "group": "clipboard@1"
        },
        {
          "command": "aweshelf.copyResumeCommand",
          "when": "view == aweshelfBookmarks && viewItem == aweshelfBookmark",
          "group": "clipboard@2"
        },
        {
          "command": "aweshelf.openProjectPath",
          "when": "view == aweshelfBookmarks && viewItem == aweshelfBookmark",
          "group": "clipboard@3"
        },
        {
          "command": "aweshelf.removeBookmark",
          "when": "view == aweshelfBookmarks && viewItem == aweshelfBookmark",
          "group": "navigation@4"
        }
      ]
    }
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.6.0",
    "typescript": "^5.8.3"
  }
}
